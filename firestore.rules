rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "bmassk3@gmail.com" && request.auth.token.email_verified == true
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'joinDate', 'vipLevel', 'storageUsed', 'storageLimit', 'balance', 'accountStatus']) &&
             data.uid is string && data.email is string &&
             data.storageUsed is number && data.storageLimit is number;
    }

    function isValidFile(data) {
      return hasOnlyAllowedFields(['fileId', 'uid', 'folderId', 'fileName', 'fileType', 'fileSize', 'downloadURL', 'uploadDate', 'visibility', 'views', 'downloads', 'aiTags', 'ocrText']) &&
             data.fileId is string && data.uid is string && data.fileName is string &&
             data.fileSize is number && data.downloadURL is string;
    }

    function isValidFolder(data) {
      return hasOnlyAllowedFields(['folderId', 'uid', 'parentId', 'folderName', 'createdAt']) &&
             data.folderId is string && data.uid is string && data.folderName is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if (isOwner(uid) && isValidUser(request.resource.data) && 
                       request.resource.data.vipLevel == resource.data.vipLevel &&
                       request.resource.data.storageLimit == resource.data.storageLimit) || isAdmin();
      allow delete: if isAdmin();
    }

    // Files
    match /files/{fileId} {
      allow read: if isAuthenticated() && (resource.data.visibility == "PUBLIC" || isOwner(resource.data.uid) || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidFile(request.resource.data);
      allow update: if (isOwner(resource.data.uid) && isValidFile(request.resource.data)) || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // Folders
    match /folders/{folderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.uid) || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidFolder(request.resource.data);
      allow update: if (isOwner(resource.data.uid) && isValidFolder(request.resource.data)) || isAdmin();
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }
  }
}
